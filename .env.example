# Turso (libsql) — https://turso.tech
TURSO_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# Google Gemini Flash — https://aistudio.google.com
GEMINI_API_KEY=

# Admin credentials (single user)
ADMIN_USER=admin
# Generate with: pnpm gen:password <your-password>
ADMIN_PASSWORD_HASH=

# JWT signing secret (random 32+ char string)
JWT_SECRET=

# Public origin — required in production for CSRF protection
# Example: https://repodex.yourdomain.com
PUBLIC_ORIGIN=

# GitHub Personal Access Token — optional but recommended
# Raises API rate limit from 60 to 5000 req/hour
# https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

NODE_ENV=development
